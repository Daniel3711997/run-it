{
    "name": "run-it",
    "version": "1.0.15",
    "displayName": "Run It",
    "description": "Runs VSCode commands on file changes",
    "keywords": [
        "run",
        "commands",
        "file",
        "changes"
    ],
    "icon": "assets/icon.png",
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "main": "./dist/extension.js",
    "publisher": "UnpackSoftware",
    "repository": {
        "type": "git",
        "url": "https://github.com/Daniel3711997/run-it"
    },
    "contributes": {
        "configuration": {
            "title": "Run It",
            "properties": {
                "run-it.globalDebug": {
                    "type": "boolean",
                    "description": "(Global, will log everything) Whether to log debug information to the output channel, useful for troubleshooting"
                },
                "run-it.commands": {
                    "type": "array",
                    "description": "Commands to run on file changes",
                    "items": {
                        "type": "object",
                        "required": [
                            "files",
                            "commands"
                        ],
                        "properties": {
                            "commands": {
                                "type": "array",
                                "description": "The VSCode commands to run",
                                "items": {
                                    "type": "string"
                                }
                            },
                            "files": {
                                "type": "array",
                                "description": "The files to watch for changes as glob patterns relative to the workspace root. e.g. 'src/**/*.ts' to watch all TypeScript files in the 'src' directory. https://code.visualstudio.com/docs/editor/glob-patterns",
                                "items": {
                                    "type": "string"
                                }
                            },
                            "delay": {
                                "type": "number",
                                "description": "The delay in milliseconds to wait after a file change before running the commands"
                            },
                            "debug": {
                                "type": "boolean",
                                "description": "Whether to log debug information to the output channel, useful for troubleshooting"
                            }
                        }
                    }
                }
            }
        }
    },
    "scripts": {
        "knip": "knip",
        "prepare": "husky",
        "test": "vscode-test",
        "check-types": "tsc --noEmit",
        "postinstall": "patch-package",
        "commit": "git add . && git-cz",
        "watch": "npm-run-all -p watch:*",
        "vscode:prepublish": "npm run package",
        "compile-tests": "tsc -p . --outDir out",
        "watch-tests": "tsc -p . -w --outDir out",
        "watch:esbuild": "node esbuild.js --watch",
        "lint": "eslint --no-error-on-unmatched-pattern --report-unused-disable-directives src",
        "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
        "compile": "npm run check-types && npm run lint && node esbuild.js",
        "pretest": "npm run compile-tests && npm run compile && npm run lint",
        "check-outdated": "check-outdated --columns name,type,current,latest,changes",
        "check-spell": "cspell --dot --no-progress --no-must-find-files \"**/*.{js,ts,json}\"",
        "package": "npm run check-spell && npm run check-types && npm run lint && node esbuild.js --production"
    },
    "engines": {
        "vscode": "^1.100.0"
    },
    "config": {
        "commitizen": {
            "path": "@commitlint/cz-commitlint"
        }
    },
    "lint-staged": {
        "**/*.{js,ts}": [
            "eslint --no-error-on-unmatched-pattern --report-unused-disable-directives"
        ],
        "**/*.{js,ts,json}": [
            "prettier --write",
            "cspell --dot --no-progress --no-must-find-files"
        ]
    },
    "devDependencies": {
        "@commitlint/cli": "^20.1.0",
        "@commitlint/config-conventional": "^20.0.0",
        "@commitlint/cz-commitlint": "^20.1.0",
        "@eslint/css": "^0.14.1",
        "@eslint/eslintrc": "^3.3.1",
        "@eslint/js": "^9.39.1",
        "@eslint/json": "^0.14.0",
        "@eslint/markdown": "^7.5.1",
        "@stylistic/eslint-plugin": "^5.6.1",
        "@types/mocha": "^10.0.10",
        "@types/node": "^22",
        "@types/vscode": "^1.100.0",
        "@vscode/test-cli": "^0.0.12",
        "@vscode/test-electron": "^2.5.2",
        "check-outdated": "^2.14.0",
        "cross-env": "^10.1.0",
        "cspell": "^9.3.2",
        "esbuild": "^0.27.0",
        "eslint": "^9",
        "eslint-config-prettier": "^10.1.8",
        "eslint-import-resolver-node": "^0.3.9",
        "eslint-import-resolver-typescript": "^4.4.4",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-jest": "^29.2.1",
        "eslint-plugin-n": "^17.23.1",
        "eslint-plugin-perfectionist": "^4.15.1",
        "eslint-plugin-promise": "^7.2.1",
        "eslint-plugin-unicorn": "^62.0.0",
        "globals": "^16.5.0",
        "husky": "^9.1.7",
        "inquirer": "^9.3.7",
        "knip": "^5.70.1",
        "lint-staged": "^16.2.7",
        "npm-run-all": "^4.1.5",
        "patch-package": "^8.0.1",
        "prettier": "^3.6.2",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.47.0"
    },
    "packageManager": "npm@11.6.3+sha512.4085a763162e0e3acd19a4e9d23ad3aa0978e501ccf947dd7233c12a689ae0bb0190763c4ef12366990056b34eec438903ffed38fde4fbd722a17c2a7407ee92"
}
